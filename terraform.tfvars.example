aws_region  = "us-east-1"
aws_profile = "default"

cluster_name    = "salvia-eks"
cluster_version = "1.30"

vpc_cidr    = "10.0.0.0/16"
environment = "dev"

node_group_instance_types = ["t3.medium"]
node_group_desired_size   = 2
node_group_min_size       = 1
node_group_max_size       = 4

# Backend remoto de Terraform (S3 + DynamoDB).
# Sustituye <account-id> por el ID de tu cuenta de AWS.
tf_state_bucket         = "salvia-terraform-state-us-east-1-<account-id>"
tf_state_key            = "eks/terraform.tfstate"
tf_state_dynamodb_table = "salvia-terraform-locks"

